# OpenAI Configuration
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_TEXT_MODEL=gemini-1.5-flash  
GROQ_API_KEY=

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=economic_data

# Application Configuration
APP_NAME=LLM Economic Analysis System
APP_VERSION=1.0.0
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
# API_KEY=your-secret-api-key-12345

# Data Configuration
DATA_DIR=data/raw
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_PERIOD=60

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_ENABLED=true

# WAHA WhatsApp Configuration
WAHA_URL=
WAHA_API_KEY=
WAHA_ENABLED=
WHATSAPP_VERIFY_TOKEN=

# n8n Webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ask

# DEV
MONGO_URL=host.docker.internal:27017
# PROD
MONGO_URL_2=

DB_NAME=llmautomationai
