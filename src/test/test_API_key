#!/usr/bin/env python3
# test_request.py - Simple test script for webhooks

import requests
import json
import os
from dotenv import load_dotenv

load_dotenv()

# ============================================
# CONFIGURATION
# ============================================

# Your FastAPI webhook URL
API_WEBHOOK_URL = "http://localhost:8000/api/v1/agent/webhook"

# FIX: Use GROQ_API_KEY (matches what auth.py expects)
API_KEY = os.getenv("GROQ_API_KEY")  # <-- Changed this line only

# ============================================
# TEST FUNCTIONS
# ============================================

def test_webhook():
    """Test FastAPI webhook"""
    headers = {
        "Content-Type": "application/json",
        "X-API-Key": API_KEY
    }
    
    payload = {
        "question": "What is BI rate?",
        "email": "test@example.com"
    }
    
    print(f"📡 Sending to: {API_WEBHOOK_URL}")
    print(f"📦 Payload: {json.dumps(payload, indent=2)}")
    print("-" * 50)
    
    try:
        response = requests.post(API_WEBHOOK_URL, json=payload, headers=headers)
        print(f"✅ Status Code: {response.status_code}")
        
        if response.status_code == 200:
            print(f"📝 Response: {json.dumps(response.json(), indent=2)}")
        else:
            print(f"❌ Error: {response.text}")
            
    except requests.exceptions.ConnectionError:
        print("❌ Connection error - is FastAPI running?")
        print("   Start with: python -m src.main")
    except Exception as e:
        print(f"❌ Error: {e}")

if __name__ == "__main__":
    test_webhook()